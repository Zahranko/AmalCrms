{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=<SQL_SERVER_INSTANCE>;Database=CRMS;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "<YOUR_JWT_SECRET_KEY_MIN_32_CHARS>",
    "Issuer": "CRMS",
    "Audience": "CRMSClient",
    "ExpiryMinutes": 480
  },
  "AdminSeed": {
    "Username": "admin",
    "Password": "<INITIAL_ADMIN_PASSWORD>"
  }
}
